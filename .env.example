# ── Azure Function integration (frontend) ────────────────────────────────────
# Copy to .env.local and fill in. These are PUBLIC (baked into the SPA bundle) —
# a base URL and a client id, NOT secrets. The Graph client secret lives ONLY in
# the Azure Function App settings, never here.

# Base URL of the Function App (no trailing slash).
VITE_UPLOAD_FN_BASEURL=https://gcp-upload.azurewebsites.net

# Client id registered with the portal for implicit grant flow. Must match the
# `ImplicitGrantFlow/RegisteredClientId` site setting. The SPA passes it to
# /_services/auth/token; the token's aud/appid equals this value. Any GUID the
# portal has registered works — reusing the app registration's client id is fine.
VITE_PORTAL_TOKEN_CLIENT_ID=00000000-0000-0000-0000-000000000000

# ── Legacy MSAL vars (no longer used) ────────────────────────────────────────
# Auth now uses the Power Pages portal token endpoint instead of MSAL, because
# the SPA runs in a sandboxed iframe where MSAL's silent flow times out. These
# are kept only as a fallback source for VITE_PORTAL_TOKEN_CLIENT_ID and can be
# removed once .env files set VITE_PORTAL_TOKEN_CLIENT_ID explicitly.
# VITE_MSAL_CLIENT_ID=00000000-0000-0000-0000-000000000000
# VITE_MSAL_TENANT_ID=00000000-0000-0000-0000-000000000000
# VITE_UPLOAD_API_SCOPE=api://00000000-0000-0000-0000-000000000000/access_as_user
